{    "settings": {
        "titles"  : "left",
    },
    "metadata" : {
        "keys": [ "title", "sorttitle", "subtitle", "artist", "time", "tempo" ],
        "strict": true,
    },
    "diagrams": {
        "show": "all",
    },
    "chords" : [
        {
            "name"    : "G",
            "base"    : 1,
            "frets"   : [ 3, 2, 0, 0, 3, 3 ],
            "fingers" : [ 2, 1, 0, 0, 3, 4 ]
        },
    ],
    "contents" : [ // Table of content
        {
            "fields"   : [ "songindex" ],
            "label"    : "Obsah",
            "line"     : "%{title}%{artist| - %{}}",
            "pageno"   : "%{page}",
            "omit"     : false,
            "template" : "stdtoc",
        },
        { 
            "fields"   : [ "sorttitle", "songindex" ],
            "label"    : "Obsah Abecedně",
            "line"     : "%{title}",
            "pageno"   : "%{page}",
            "omit"     : false,
            "template" : "stdtoc",
        },
        { 
            "fields"   : [ "artist", "sorttitle" ],
            "label"    : "Obsah dle Autorů",
            "line"     : "%{artist|%{} - }%{title}",
            "pageno"   : "%{page}",
            "omit"     : true,
            "template" : "stdtoc",
        },
    ],
    "pdf": {
        "theme": { "background": "#eff1f5" },
        "fontdir": [ "./fonts" ],
        "fontconfig": {
            "coolvetica": {
                "":           "coolvetica/Coolvetica Rg.otf",
                "bold":       "coolvetica/Coolvetica Hv Comp.otf",
                "italic":     "coolvetica/Coolvetica Rg It.otf"
            },
            "garet": {
                "":     "garet/Garet-Book.otf",
                "bold": "garet/Garet-Heavy.otf"
            },
            "orangejuice": {
                "": "orange_juice/orange juice 2.0.ttf"
            },
        },
        "fonts": {
            "title": {
                "description": "orangejuice 18",
                "color": "#4c4f69"
            },
            "subtitle": {
                "description": "coolvetica 12"
            },
            "text": {
                "description": "garet 10",
                "color": "#4c4f69"
            },
            "chord": {
                "description": "garet 9",
                "color": "#179299"
            },
            "chorus": {
                "color": "#5c5f77"
            }
        },
        "pagealign-songs": 0, 
        "info": { // PDF Metadata
            "title": "Zpěvník",
            "author": "Ivo Žitnik",
        },
        // "showlayout" : true, // REMOVE LATER - ONLY FOR DEBUG
        "margintop"  : 50,
        "headspace"  : 30,
        "chorus": {
            "indent" : 0,
            "tag" : "Ref",
            "bar": {
                "width": 1.5,
                "color": "#7c7f93"
            },
            "recall": {
                "tag" : "Ref",
            },
        },
        "diagrams": {
            "show"     : "right", // or top, right, below, false
            "width"    : 6,      // of a cell
            "height"   : 6,      // of a cell
            "vcells"   : 4,      // vertically
            "linewidth": 0.1,    // of a cell width
            "nutwidth" : 4,      // linewidth
            "hspace"   : 3.95,   // horizontal space between, fraction of width
            "vspace"   : 3,      // vertical space between, fraction of height
            "dotsize"  : 0.6,    // of a cell
            "barwidth" : 0.6,    // of a dot
            "fingers"  : false,   // show fingering if available (or "below")
        },
        "outlines" : [ // Clickable links in pdf
            { "fields"   : [ "title", "artist" ],
              "label"    : "By Title",
              "line"     : "%{title}%{artist| - %{}}",
              "collapse" : false,
              "letter"   : 5,
              "fold"     : false,
            },
            { "fields"   : [ "artist", "title" ],
              "label"    : "By Artist",
              "line"     : "%{artist|%{} - }%{title}",
              "collapse" : false,
              "letter"   : 5,
              "fold"     : false,
            },
        ],
        "formats": {
            "first": {
                "title": [ "", "%{title}%{artist| - %{}}", "%{time}" ],
                "subtitle": false,
                "footer": [ "", "%{page}", "" ],
            },
            "title": {
                "title": [ "", "%{title}%{artist| - %{}}", "%{time}" ],
                "subtitle": false,
                "footer": [ "", "%{page}", "" ],
            },
            "default": {
                "title": false,
                "subtitle": false,
                "footer": [ "",  "%{page}", "%{title}%{artist| - %{}}" ],
            },
        },
    }
}
